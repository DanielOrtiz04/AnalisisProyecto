@* RF-1: Registro de Usuarios *@
@page "/registro"
@using ReservaCancha.Models
@inject NavigationManager NavManager

<PageTitle>Crear cuenta | ReservaCancha</PageTitle>

<div class="rc-wrap">

    <div class="rc-logo">
        <div class="rc-logo-icon">⏱</div>
        <span class="rc-app-name">ReservaCancha</span>
    </div>

    <h1 class="rc-title">Crear cuenta</h1>
    <p class="rc-subtitle">Ingresa tus datos para comenzar a reservar</p>

    @if (registroExitoso)
    {
        <div class="rc-toast rc-toast--success" role="alert">
            ✓ ¡Registro exitoso! Serás redirigido al inicio.
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMensaje))
    {
        <div class="rc-toast rc-toast--error" role="alert">
            ⚠ @errorMensaje
        </div>
    }

    <div class="rc-card">
        <EditForm Model="@modelo" OnValidSubmit="HandleRegistro">
            <DataAnnotationsValidator />

            <div class="rc-field">
                <label for="nombre">Nombre completo</label>
                <InputText id="nombre" class="rc-input" @bind-Value="modelo.Nombre" placeholder="Ana García" />
                <ValidationMessage For="@(() => modelo.Nombre)" class="rc-err" />
            </div>

            <div class="rc-field">
                <label for="correo">Correo electrónico</label>
                <InputText id="correo" class="rc-input" @bind-Value="modelo.Correo" placeholder="ana@ejemplo.com" />
                <ValidationMessage For="@(() => modelo.Correo)" class="rc-err" />
            </div>

            <div class="rc-field">
                <label for="telefono">Número de teléfono</label>
                <InputText id="telefono" class="rc-input" @bind-Value="modelo.Telefono" placeholder="+502 5555-1234" />
                <ValidationMessage For="@(() => modelo.Telefono)" class="rc-err" />
            </div>

            <div class="rc-field">
                <label for="password">Contraseña</label>
                <InputText id="password" class="rc-input" @bind-Value="modelo.Password" placeholder="Mínimo 8 caracteres" type="password" />
                <ValidationMessage For="@(() => modelo.Password)" class="rc-err" />
            </div>

            <div class="rc-field">
                <label for="password2">Confirmar contraseña</label>
                <InputText id="password2" class="rc-input" @bind-Value="modelo.ConfirmarPassword" placeholder="Repite tu contraseña" type="password" />
                <ValidationMessage For="@(() => modelo.ConfirmarPassword)" class="rc-err" />
            </div>

            <button type="submit" class="rc-btn" disabled="@cargando">
                @if (cargando)
                {
                    <span class="rc-spinner"></span>
                }
                else
                {
                    <span>Crear cuenta</span>
                }
            </button>
        </EditForm>
    </div>

    <p class="rc-footer-link">
        ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
    </p>
</div>

@code {
    private RegistroModelo modelo = new();
    private bool cargando = false;
    private bool registroExitoso = false;
    private string? errorMensaje;

    private async Task HandleRegistro()
    {
        cargando = true;
        errorMensaje = null;
        registroExitoso = false;

        try
        {
            using var http = new System.Net.Http.HttpClient();
            var respuesta = await http.PostAsJsonAsync("http://localhost:5000/api/usuarios/registrar", new
            {
                nombre   = modelo.Nombre,
                correo   = modelo.Correo,
                telefono = modelo.Telefono,
                password = modelo.Password,
            });

            if (respuesta.IsSuccessStatusCode)
            {
                registroExitoso = true;
                modelo = new RegistroModelo();
                await Task.Delay(2000);
                NavManager.NavigateTo("/");
            }
            else if (respuesta.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMensaje = "El correo ya está registrado.";
            }
            else
            {
                errorMensaje = "Ocurrió un error. Intenta de nuevo.";
            }
        }
        catch
        {
            errorMensaje = "No se pudo conectar al servidor.";
        }
        finally
        {
            cargando = false;
        }
    }
}

<style>
    .rc-wrap { max-width: 460px; margin: 2rem auto; padding: 0 1rem; font-family: 'Segoe UI', system-ui, sans-serif; }
    .rc-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 1.75rem; }
    .rc-logo-icon { width: 36px; height: 36px; background: #E6F1FB; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .rc-app-name { font-size: 15px; font-weight: 600; color: #185FA5; }
    .rc-title { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
    .rc-subtitle { font-size: 14px; color: #5F5E5A; margin-bottom: 1.5rem; }
    .rc-toast { padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 1rem; }
    .rc-toast--success { background: #EAF3DE; color: #3B6D11; border: 0.5px solid #C0DD97; }
    .rc-toast--error { background: #FCEBEB; color: #A32D2D; border: 0.5px solid #F7C1C1; }
    .rc-card { background: #fff; border: 0.5px solid rgba(0,0,0,.12); border-radius: 12px; padding: 1.5rem; }
    .rc-field { margin-bottom: 1rem; }
    .rc-field label { display: block; font-size: 13px; font-weight: 500; color: #5F5E5A; margin-bottom: 5px; }
    .rc-input { width: 100%; padding: 9px 12px; font-size: 14px; border: 0.5px solid rgba(0,0,0,.2); border-radius: 8px; outline: none; transition: border-color .15s; }
    .rc-input:focus { border-color: #185FA5; box-shadow: 0 0 0 3px rgba(24,95,165,.15); }
    .rc-err { font-size: 12px; color: #E24B4A; margin-top: 4px; display: block; }
    .rc-btn { width: 100%; padding: 10px; font-size: 14px; font-weight: 500; background: #185FA5; color: #fff; border: none; border-radius: 8px; cursor: pointer; margin-top: .5rem; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .15s; }
    .rc-btn:hover:not(:disabled) { background: #0C447C; }
    .rc-btn:disabled { background: #B4B2A9; cursor: not-allowed; }
    .rc-spinner { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.35); border-top-color: #fff; border-radius: 50%; animation: spin .7s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .rc-footer-link { text-align: center; font-size: 13px; color: #5F5E5A; margin-top: 1.25rem; }
    .rc-footer-link a { color: #185FA5; text-decoration: none; font-weight: 500; }
</style>
